<Window x:Class="SupabaseUserManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SupabaseUserManager"
        xmlns:views="clr-namespace:SupabaseUserManager.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="300" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel>
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="_File">
                    <MenuItem Header="Preferences" Command="{Binding OpenConfigCommand}" />
                    <Separator />
                    <MenuItem Header="Exit"/>
                </MenuItem>
            </Menu>
            <Grid />
        </DockPanel>

        <views:UserListingView Grid.Row="1"/>
    </Grid>
</Window>
